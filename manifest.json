{
  "manifest_version": 3,
  "name": "WP Design Auditor",
  "version": "1.0",
  "description": "Audits CSS - Desktop/Mobile, light/dark, finds semantic tokens across SERP",
  "permissions": ["tabs", "scripting", "debugger"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content/classification-map.csv", "content/css-property-config.csv"],
      "matches": ["<all_urls>"]
    }
  ]
}
